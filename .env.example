# === Qdrant Vector DB ===
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=code_chunks

# === Ollama (Self-hosted LLM) ===
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder

# === Embedding ===
EMBEDDING_MODEL=microsoft/unixcoder-base
EMBEDDING_DIM=768

# === Chunking ===
CHUNK_MAX_TOKENS=512
CHUNK_OVERLAP_LINES=15
CHUNK_FALLBACK_WINDOW=60

# === Ingestion ===
MAX_FILE_SIZE_BYTES=1048576
BATCH_SIZE=32

# === Logging ===
LOG_LEVEL=INFO
