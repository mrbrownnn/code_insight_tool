# === Qdrant Vector DB ===
QDRANT_HOST=localhost
QDRANT_PORT= YOUR_PORT_HERE
QDRANT_COLLECTION_NAME=code_chunks

# === Ollama (Self-hosted LLM) ===
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder

# === LangChain Settings ===
LLM_MODEL=qwen2.5-coder
LLM_TEMPERATURE= YOUR LLM_TEMPERATURE_HERE
RATE_LIMIT= YOUR_RATE_LIMIT_HERE  # Max requests per second to Ollama
MEMORY_K= YOUR_MEMORY_K_HERE  # Number of past interactions to remember
API_KEY= your_api_key_here 😂
# === Embedding ===
EMBEDDING_MODEL=microsoft/unixcoder-base
EMBEDDING_DIM=768

# === Chunking ===
CHUNK_MAX_TOKENS= YOUR_CHUNK_MAX_TOKENS_HERE
CHUNK_OVERLAP_LINES= YOUR_CHUNK_OVERLAP_LINES_HERE
CHUNK_FALLBACK_WINDOW= YOUR_CHUNK_FALLBACK_WINDOW_HERE

# === Ingestion ===
MAX_FILE_SIZE_BYTES=1048576
BATCH_SIZE=32

# === Logging ===
LOG_LEVEL=INFO
